{
  "name": "gctools",
  "version": "0.1.0",
  "description": "Command line utilities for working with Ghost content",
  "repository": "https://github.com/TryGhost/gctools",
  "author": "Ghost Foundation",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=22.21.1"
  },
  "license": "MIT",
  "bin": {
    "gctools": "./bin/cli.js"
  },
  "eslintIgnore": [
    "**/node_modules/**"
  ],
  "scripts": {
    "dev": "node bin/cli.js",
    "gctools": "gctools",
    "test:only": "node --test --experimental-test-module-mocks test/*.test.js",
    "test": "node --test --experimental-test-module-mocks test/*.test.js && yarn lint",
    "lint": "eslint . --ext .js --cache",
    "update": "git pull origin main && yarn"
  },
  "devDependencies": {
    "eslint": "8.57.1",
    "eslint-plugin-ghost": "3.5.0"
  },
  "dependencies": {
    "@inquirer/confirm": "3.2.0",
    "@tryghost/admin-api": "1.14.7",
    "@tryghost/listr-smart-renderer": "0.5.24",
    "@tryghost/logging": "2.5.5",
    "@tryghost/mg-assetscraper": "0.4.37",
    "@tryghost/mg-fs-utils": "0.16.7",
    "@tryghost/pretty-cli": "1.2.52",
    "@tryghost/zip": "1.1.54",
    "axios": "1.13.6",
    "bluebird": "3.7.2",
    "chalk": "5.6.2",
    "cli-progress": "3.12.0",
    "fs-extra": "11.3.4",
    "glob": "10.5.0",
    "inquirer": "9.3.8",
    "inquirer-datepicker-prompt": "0.4.3",
    "inquirer-search-checkbox": "1.0.0",
    "inquirer-search-list": "1.2.6",
    "jsonwebtoken": "9.0.3",
    "listr": "0.14.3",
    "lodash": "4.17.23",
    "lorem-ipsum": "2.0.8",
    "superbytes": "2.0.1",
    "title-case": "4.3.2",
    "tty-table": "5.0.0"
  }
}
